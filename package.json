{
  "name": "html-express-js",
  "version": "5.0.1",
  "description": "An Express template engine to render HTML views using native JavaScript",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=16"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22.19",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=10.9.3",
      "onFail": "error"
    }
  },
  "files": [
    "src/index.js",
    "src/index.d.ts"
  ],
  "scripts": {
    "format": "prettier --write '**/*' --log-level=warn",
    "format-check": "prettier --check '**/*' --ignore-unknown",
    "test": "npm run test:src && npm run type-check && npm run format-check",
    "test:src": "mocha src/**/*.tests.js",
    "start": "node ./example/server.js",
    "type-check": "tsc -p tsconfig.json",
    "prepare": "husky install",
    "build": "tsc -p tsconfig.build.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markcellus/html-express-js.git"
  },
  "keywords": [
    "html",
    "express",
    "views",
    "template",
    "engine"
  ],
  "author": "Mark",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/markcellus/html-express-js/issues"
  },
  "homepage": "https://github.com/markcellus/html-express-js#readme",
  "dependencies": {
    "glob": "^13.0.6"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/express": "^5.0.6",
    "@types/mocha": "^10.0.10",
    "@types/reload": "^3.2.3",
    "@types/sinon": "^21.0.1",
    "chai": "^6.2.2",
    "chokidar": "^5.0.0",
    "express": "^5.2.1",
    "husky": "^9.1.7",
    "mocha": "^11.7.5",
    "prettier": "^3.8.1",
    "release-it": "19.2.4",
    "reload": "^3.4.3",
    "sinon": "^21.0.3",
    "typescript": "^6.0.2"
  }
}
